server:
  port: 8081

eureka:
  client:
    service-url:
      defaultZone: http://172.31.37.213:8761/eureka/
spring:
  application:
    name: api-gateway
  config:
    import: "optional:configserver:http://config-server:8888"
  cloud:
    gateway:
      globalcors:
        add-to-simple-url-handler-mapping: true
        cors-configurations:
          '[/**]':
            allowedOriginPatterns: "*"
            allowedMethods:
              - GET
              - POST
              - PUT
              - DELETE
              - OPTIONS
            allowedHeaders: "*"
            allowCredentials: true
      routes:
        - id: consulta-service
          uri: http://172.31.45.47:8083
          predicates:
            - Path=/consulta/**
      discovery:
        locator:
          enabled: true
          lower-case-service-id: true
logging:
  level:
    org.springframework.cloud.gateway: DEBUG
    org.springframework.web.cors: TRACE
    org.springframework.web.server.adapter.HttpWebHandlerAdapter: TRACE
